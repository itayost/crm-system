# Database Configuration (Required)
# PostgreSQL connection string from Supabase or your database provider
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

# Authentication (Required)
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# WhatsApp Business API (Optional - for WhatsApp notifications)
# Get these from Meta Business Platform: https://business.facebook.com
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_BUSINESS_ID=""
WHATSAPP_WEBHOOK_SECRET=""
OWNER_PHONE="972501234567"  # Your phone in international format (without +)

# Email Configuration (Optional - future feature)
EMAIL_HOST=""
EMAIL_PORT=""
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_FROM=""

# External Integrations (Optional)
# For webhook security
WEBHOOK_SECRET=""

# Morning (Green Invoice) API - Israeli Invoicing System
# Get API key from: https://app.greeninvoice.co.il/settings/api
MORNING_API_KEY=""
MORNING_API_SECRET=""
MORNING_API_URL="https://api.greeninvoice.co.il/api/v1"
ENABLE_MORNING_INTEGRATION="false"

# Google Calendar (Optional - future feature)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# File Storage (Optional - future feature)
# For uploading project files, invoices, etc.
STORAGE_PROVIDER="local"  # or "s3", "cloudinary"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET=""
STORAGE_REGION=""

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
MIXPANEL_TOKEN=""

# Error Tracking (Optional)
SENTRY_DSN=""

# Feature Flags
ENABLE_WHATSAPP="false"
ENABLE_EMAIL_NOTIFICATIONS="false"
ENABLE_PUBLIC_API="true"

# Development
NODE_ENV="development"  # or "production"

# Agent API key — used by project-health-agent to authenticate to /api/v1/agent/*.
# 32-byte hex; rotate by regenerating + updating both crm-system and agent env.
AGENT_API_KEY=